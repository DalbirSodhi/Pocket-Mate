# Copy this file to .env and add local project values as needed.

# Public Supabase values for local development.
# For Expo, also copy these into apps/mobile/.env.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase secret.
# Never expose this in the mobile app.
SUPABASE_SERVICE_ROLE_KEY=
